#!/usr/bin/env python3
"""
StormOS Utilities Program v5.1 - Improved Terminal Handling
Uses gnome-terminal (with fallback) and pkexec for better reliability.
"""

import os
import shutil
import subprocess
import sys

# Ensure GTK 3 is used by setting the GI_TYPELIB_PATH to the correct location
os.environ['GI_TYPELIB_PATH'] = '/usr/lib/girepository-1.0'

import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk


# ============================================================
# TERMINAL HANDLING (gnome-terminal first, then fallbacks)
# ============================================================

def find_terminal():
    """Find available terminal emulator, preferring gnome-terminal."""
    terminals = ["gnome-terminal", "xfce4-terminal", "xterm", "konsole"]
    for term in terminals:
        if shutil.which(term):
            return shutil.which(term)
    return None


def run_command(command_str, hold=True):
    """
    Run a command string in a terminal with proper PTY handling.
    Uses gnome-terminal if available, else falls back to other terminals.
    """
    # Check if command starts with sudo and pkexec exists - use pkexec for GUI password prompt
    if command_str.startswith("sudo ") and shutil.which("pkexec"):
        # Replace 'sudo' with 'pkexec'
        pkexec_cmd = command_str.replace("sudo ", "pkexec ", 1)
        try:
            subprocess.Popen(pkexec_cmd, shell=True, start_new_session=True,
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except Exception:
            pass

    term = find_terminal()
    if not term:
        error_dialog = Gtk.MessageDialog(parent=None,
                                         flags=Gtk.DialogFlags.MODAL,
                                         type=Gtk.MessageType.ERROR,
                                         buttons=Gtk.ButtonsType.OK,
                                         message_format="No terminal found.\nPlease install gnome-terminal or xfce4-terminal.")
        error_dialog.run()
        error_dialog.destroy()
        return False

    term_name = os.path.basename(term)

    # Build the shell command that will be run inside the terminal
    if hold:
        # Keep terminal open after command finishes
        shell_cmd = f'bash -c "{command_str}; echo; echo \'Press Enter to close...\'; read"'
    else:
        shell_cmd = f'bash -c "{command_str}"'

    # Construct terminal arguments
    if term_name == "gnome-terminal":
        # Use -- to separate options from the command
        args = [term, "--title", "StormOS Utility", "--", "bash", "-c", shell_cmd]
    elif term_name == "xfce4-terminal":
        args = [term, "--disable-server", "--title", "StormOS Utility", "--command", shell_cmd]
    elif term_name == "xterm":
        args = [term, "-title", "StormOS Utility", "-e", shell_cmd]
    else:
        # Generic fallback
        args = [term, "-e", shell_cmd]

    try:
        subprocess.Popen(args, start_new_session=True,
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except Exception as e:
        error_dialog = Gtk.MessageDialog(parent=None,
                                         flags=Gtk.DialogFlags.MODAL,
                                         type=Gtk.MessageType.ERROR,
                                         buttons=Gtk.ButtonsType.OK,
                                         message_format=f"Failed to launch terminal:\n{str(e)}")
        error_dialog.run()
        error_dialog.destroy()
        return False


class MainWindow(Gtk.Window):
    def __init__(self):
        Gtk.Window.__init__(self, title="StormOS Utilities Program v5.1")
        self.set_border_width(10)
        self.set_default_size(600, 400)

        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        self.add(hbox)

        notebook_vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        hbox.pack_start(notebook_vbox, True, True, 0)

        notebook = Gtk.Notebook()
        notebook.set_tab_pos(Gtk.PositionType.LEFT)
        notebook_vbox.pack_start(notebook, True, True, 0)

        self.create_maintenance_tab(notebook)
        self.create_game_utilities_tab(notebook)
        self.create_printer_tab(notebook)
        self.create_arch_university_tab(notebook)
        self.create_about_us_tab(notebook)

    def create_button_with_icon(self, label, command, icon_name):
        button = Gtk.Button()
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        image = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.BUTTON)
        label_widget = Gtk.Label(label=label)
        box.pack_start(image, False, False, 5)
        box.pack_start(label_widget, False, False, 5)
        button.add(box)
        button.connect("clicked", self.run_command, command)
        return button

    def run_command(self, widget, command):
        """Run the given command string using our improved terminal handler."""
        run_command(command)

    def create_maintenance_tab(self, notebook):
        grid = Gtk.Grid()
        grid.set_column_homogeneous(True)
        grid.set_row_homogeneous(True)

        commands = [
            ("Step 1. Refresh Mirrors", "sudo reflector --verbose -l 20 --sort rate --save /etc/pacman.d/mirrorlist", "view-refresh"),
            ("Step 2. System Updates", "sudo pacman -Syyu --noconfirm", "system-software-update"),
            ("Step 3. (Optional) Aur Updates", "yay -Syyu --noconfirm", "system-software-update"),
            ("Step 4. (Optional) Arch Keyring Updater", "upkeyring", "system-lock-screen"),
            ("Step 4a. (Optional) Renew Arch Keyring", "upsystem", "system-lock-screen"),
            ("Step 5. Install Teamviewer", "tinstall", "applications-internet"),
            ("Step 6. Install Lshw", "sudo pacman -S lshw --noconfirm", "applications-system"),
            ("Step 7. Install i2c-tools for decode-dimms", "sudo pacman -S i2c-tools --noconfirm", "applications-system"),
            ("Step 8. Install Nvidia drivers (dkms) after that, (Reboot)", "sudo pacman -S nvidia-open-dkms lib32-nvidia-utils lib32-opencl-nvidia lib32-primus_vk lib32-libvdpau cuda-tools cuda opencl-nvidia primus_vk --noconfirm", "video-display"),
            ("Step 9. Install Nvidia-390xx drivers (dkms) after that (Reboot)", "sudo pacman -S nvidia-390xx-dkms nvidia-390xx-utils opencl-nvidia-390xx --noconfirm", "video-display")
        ]

        for i, (label, command, icon_name) in enumerate(commands):
            button = self.create_button_with_icon(label, command, icon_name)
            grid.attach(button, 0, i, 1, 1)

        label = Gtk.Label(label="<b>Maintenance/Updates/Support</b>", use_markup=True)
        notebook.append_page(grid, label)

